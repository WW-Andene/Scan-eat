{
  "name": "scann-eat",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "check:app-size": "node tools/check-app-size.mjs",
    "pretest": "npm run check:app-size",
    "test": "node --test --experimental-strip-types tests/*.tests.ts",
    "dev": "node --experimental-strip-types src/server.ts",
    "build:web": "node build.mjs",
    "cap:add": "cap add android",
    "cap:sync": "cap sync android",
    "cap:build": "npm run build:web && npm run cap:sync",
    "dev:kotlin": "gradle run",
    "test:kotlin": "gradle test",
    "build:kotlin": "gradle installDist"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/camera": "^6.1.2",
    "@capacitor-mlkit/barcode-scanning": "^6.3.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "esbuild": "^0.24.0"
  }
}
