<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- android:windowLightNavigationBar requires API 27; minSdk here is 26, so this
         override lives in a -v27 qualified resource set instead of the base theme.
         Inherits from Theme.ScanEat.Base (values/themes.xml) and adds only the
         API-27+ item, rather than redefining every shared item here. -->
    <style name="Theme.ScanEat" parent="Theme.ScanEat.Base">
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
