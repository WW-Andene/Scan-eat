<?xml version="1.0" encoding="utf-8"?>
<!--
    Platform requirement (AppWidgetProviderInfo.initialLayout), independent of
    Glance: the widget host inflates this classic View layout for the brief
    window before GlanceAppWidget's own RemoteViews are ready, and again if
    provideGlance() ever throws. Everything else in this app is Compose - this
    is the one XML layout that has to exist for that platform contract alone.
-->
<TextView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:padding="12dp"
    android:text="@string/widget_today_loading"
    android:textSize="12sp" />
